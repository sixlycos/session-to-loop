{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sixloops.local/schemas/loop-autonomy-contract.schema.json",
  "title": "SixLoops Loop Autonomy Contract",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "decision_policy",
    "self_iteration_policy",
    "subagent_control",
    "human_return_policy"
  ],
  "properties": {
    "decision_policy": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "self_iteration_policy": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "subagent_control": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "human_return_policy": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
