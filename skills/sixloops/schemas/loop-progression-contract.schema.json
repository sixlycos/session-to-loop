{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sixloops.local/schemas/loop-progression-contract.schema.json",
  "title": "SixLoops Loop Progression Contract",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "rhythm",
    "state_updates_required",
    "continue_requires",
    "stop_instead_of_continue_when",
    "handoff_rule"
  ],
  "properties": {
    "rhythm": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "state_updates_required": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "continue_requires": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_instead_of_continue_when": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "handoff_rule": {
      "type": "string",
      "minLength": 1
    }
  }
}
